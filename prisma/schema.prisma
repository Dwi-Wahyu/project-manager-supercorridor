generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(uuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  name       String
  username   String    @unique
  password   String
  avatar     String?
  last_login DateTime?
  phone_number String?
  email String?
  role       Role

  tasks_created   Task[] @relation("CreatedBy")
  tasks_updated   Task[] @relation("UpdatedBy")
  tasks_in_charge Task[] @relation("TaskInCharge")

  @@map("user")
}

model Task {
  id         Int        @id @default(autoincrement())
  project    Project    @relation(onDelete: Cascade, fields: [project_id], references: [id])
  project_id String

  name String
  lop String?
  port String?
  status     TaskStatus @default(progress)
  priority   TaskPriority

  notes String? @db.Text

  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  deleted_at DateTime?

  created_by_user   User? @relation("CreatedBy", fields: [created_by_user_id], references: [id])
  created_by_user_id String?

  updated_by_user   User? @relation("UpdatedBy", fields: [updated_by_user_id], references: [id])
  updated_by_user_id String?

  users_in_charge User[] @relation("TaskInCharge")

  @@map("task")
}

model Project {
  id String @id @default(uuid())
  
  regional String?
  pop String?
  project_number String?
  name String
  bep String?
  spk_number String?
  investment_value String?
  toc String?
  mos String?
  status String?
  rfs_date String?

  home_pass String?
  home_port Int?
  home_connected Int?
  remaining Int?
  occ Int?
  revenue String?
  year String?

  done Boolean @default(false)

  task Task[]
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  category ProjectCategory

  client Client? @relation(fields: [client_id], references: [id])
  client_id String?

  @@map("project")
}

model Client {
  id String @id @default(uuid())
  name String
  projects Project[]

  @@map("client")
}

enum ProjectCategory {
  ftth
  backbone
}

model Material {
  id Int @id @default(autoincrement())
  name String
  quantity String

  @@map("material")
}

enum TaskPriority {
  critical
  high
  medium
  low
}

enum TaskStatus {
  done
  progress
  stuck
  survey
}

enum Role {
  admin
  workers
}
